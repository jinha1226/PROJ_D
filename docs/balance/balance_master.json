{
  "version": "balance_v1",
  "design_principles": {
    "combat_pillars": {
      "melee": "stable, no resource cost, best sustained single-target baseline",
      "ranged": "safer than melee, slightly lower baseline damage, positioning advantage",
      "magic": "highest flexibility and burst, controlled by mp cost and spell level",
      "support": "low direct damage, high survival and tempo value"
    },
    "rules": {
      "spell_failure": false,
      "item_model": "fixed_base_plus_tier_plus_brand_plus_enchant",
      "essence_model": "passive_only",
      "race_role": "starting bias, not full build definition"
    }
  },
