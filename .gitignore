# Godot 4+
.godot/
/android/

# Build output
build/
export/

# Godot editor binaries / Windows SDK crumbs (never commit)
Godot_v*.exe
Godot_v*.exe.zip
Godot_v*.zip
Microsoft.Services.Store.winmd

# Node (ULPC generator tooling, if anyone runs it locally)
node_modules/

# Raw ULPC generator repo — huge; we commit the mirrored output under assets/ulpc/ instead.
# See CREDITS_LPC.md for license attribution.
Universal-LPC-Spritesheet-Character-Generator/

# DCSS reference install (tile source). Only the PNGs we actually use get
# copied into assets/dcss_tiles/ — the exe, lua, docs, dats shouldn't ship.
dcss-*-win32-tiles/
dcss-*-win32-tiles.zip

# OS
.DS_Store
Thumbs.db

# Save data (local only)
*.dat

# CI-generated build version tag
/version.txt

# NOTE: *.import files ARE committed — they carry stable Godot UIDs.
# NOTE: assets/ulpc/ IS committed so CI can build without the generator repo.
assets/ulpc/

# DCSS source clone (GPL, huge). Only referenced by tools/convert_dcss_*.py
# at author-time; the rendered data lives under assets/dcss_*/ (JSON) and
# assets/dcss_des/ (vault templates).
/crawl/

